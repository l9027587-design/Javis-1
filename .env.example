# --- Tennis stats provider (Sportradar or a RapidAPI tennis product) ---
TENNIS_API_PROVIDER=rapidapi          # "rapidapi" or "sportradar"
TENNIS_API_KEY=your_api_key_here
TENNIS_API_HOST=tennis-live-data.p.rapidapi.com   # RapidAPI host header, if applicable

# --- Odds (https://the-odds-api.com) ---
ODDS_API_KEY=your_odds_api_key_here

# --- Database (Postgres, e.g. Neon/Supabase/RDS connection string) ---
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/tennis

# --- LLM ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Model storage (optional, for S3-backed model artifacts) ---
MODEL_S3_BUCKET=
AWS_REGION=us-east-1
